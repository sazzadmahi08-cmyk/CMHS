#include <TinyGPS++.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);

TinyGPSPlus gps;

// GPS
SoftwareSerial gpsSerial(8, 7); // RX,TX

// GSM
SoftwareSerial gsmSerial(6, 5); // RX,TX

// HC-SR04 Front
#define FRONT_TRIG 2
#define FRONT_ECHO 3

// HC-SR04 Rear
#define REAR_TRIG 9
#define REAR_ECHO 10

// Sensors
#define VIBRATION_PIN 11

// Outputs
#define BUZZER 4
#define RED_LED 12
#define GREEN_LED 13

String phoneNumber = "+8801XXXXXXXXX";

long getDistance(int trigPin, int echoPin)
{
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  long duration = pulseIn(echoPin, HIGH);
  long distance = duration * 0.034 / 2;

  return distance;
}

void sendSMS(String msg)
{
  gsmSerial.println("AT");
  delay(1000);

  gsmSerial.println("AT+CMGF=1");
  delay(1000);

  gsmSerial.print("AT+CMGS=\"");
  gsmSerial.print(phoneNumber);
  gsmSerial.println("\"");
  delay(1000);

  gsmSerial.print(msg);
  delay(500);

  gsmSerial.write(26);
  delay(5000);
}

void sendLocationSMS()
{
  String sms = "ACCIDENT DETECTED!\n";

  if (gps.location.isValid())
  {
    sms += "Latitude: ";
    sms += String(gps.location.lat(), 6);

    sms += "\nLongitude: ";
    sms += String(gps.location.lng(), 6);

    sms += "\nGoogle Map:\nhttps://maps.google.com/?q=";
    sms += String(gps.location.lat(), 6);
    sms += ",";
    sms += String(gps.location.lng(), 6);
  }
  else
  {
    sms += "GPS Location Not Available";
  }

  sendSMS(sms);
}

void setup()
{
  pinMode(FRONT_TRIG, OUTPUT);
  pinMode(FRONT_ECHO, INPUT);

  pinMode(REAR_TRIG, OUTPUT);
  pinMode(REAR_ECHO, INPUT);

  pinMode(VIBRATION_PIN, INPUT);

  pinMode(BUZZER, OUTPUT);
  pinMode(RED_LED, OUTPUT);
  pinMode(GREEN_LED, OUTPUT);

  Serial.begin(9600);
  gpsSerial.begin(9600);
  gsmSerial.begin(9600);

  lcd.init();
  lcd.backlight();

  lcd.setCursor(0, 0);
  lcd.print("SYSTEM READY");

  digitalWrite(GREEN_LED, HIGH);
}

void loop()
{
  while (gpsSerial.available())
  {
    gps.encode(gpsSerial.read());
  }

  long frontDist = getDistance(FRONT_TRIG, FRONT_ECHO);
  long rearDist = getDistance(REAR_TRIG, REAR_ECHO);

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("F:");
  lcd.print(frontDist);
  lcd.print("cm");

  lcd.setCursor(9, 0);
  lcd.print("R:");
  lcd.print(rearDist);
  lcd.print("cm");

  bool warning = false;

  if (frontDist > 0 && frontDist < 20)
    warning = true;

  if (rearDist > 0 && rearDist < 20)
    warning = true;

  if (warning)
  {
    digitalWrite(BUZZER, HIGH);
    digitalWrite(RED_LED, HIGH);
    digitalWrite(GREEN_LED, LOW);

    lcd.setCursor(0, 1);
    lcd.print("WARNING !");
  }
  else
  {
    digitalWrite(BUZZER, LOW);
    digitalWrite(RED_LED, LOW);
    digitalWrite(GREEN_LED, HIGH);

    lcd.setCursor(0, 1);
    lcd.print("SAFE");
  }

  int vibration = digitalRead(VIBRATION_PIN);

  if (vibration == HIGH)
  {
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("ACCIDENT!");

    digitalWrite(BUZZER, HIGH);
    digitalWrite(RED_LED, HIGH);

    sendLocationSMS();

    delay(15000);
  }

  delay(500);
}
